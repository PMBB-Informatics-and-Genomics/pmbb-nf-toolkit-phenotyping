/*
 * pmbb-nf-toolkit-phenotyping — Nextflow configuration
 *
 * All pipeline parameters with defaults. Override via:
 *   - CLI:         --param_name value
 *   - Params file: -params-file my_params.yaml
 */

params {
    // ── Sub-pipeline toggles (all off by default; opt in as needed) ──────────
    run_preprocess          = false
    run_quantitative        = false
    run_categorical         = false
    run_risk_classification = false

    // ── Input files ──────────────────────────────────────────────────────────
    // Raw input for pre-processing (wide or long format)
    input                   = null
    // Pre-built long-format file (skip pre-processing)
    long_format_input       = null
    // Per-module parameter files
    quantitative_params     = null
    categorical_params      = null
    // Optional: file with one sample ID per line — only these samples are processed
    sample_list             = null

    // Event masking: optional path to event_mask.yaml config.
    // When set, EVENT_MASK computes windows from event ICD codes and
    // APPLY_MASK filters opted-in phenotypes before downstream calculation.
    // Phenotypes without a real date_col are unaffected (masking skipped with warning).
    event_mask_config       = null

    // ── Pre-processing options ────────────────────────────────────────────────
    input_format            = 'long'    // 'wide' or 'long'
    data_type                 = 'auto'    // 'auto' | 'ICD9' | 'ICD10' | 'quantitative' | ...
    sample_id_col           = 'auto'
    phenotype_col           = 'auto'
    value_col               = 'auto'
    date_col                = 'auto'
    reference_date          = 'today'

    // Outlier filtering
    outlier_method          = 'iqr'     // 'iqr' | 'zscore' | 'none'
    outlier_iqr_multiplier  = 1.5
    outlier_zscore_sd       = 3
    outlier_mode            = 'cap'     // 'cap' | 'remove'
    outlier_phenotypes      = null      // null = global; comma list or file = specific phenotypes

    // Scaling
    scale_phenotypes        = null      // null = no scaling; comma list or file = scale these
    scale_method            = 'zscore'  // 'zscore' | 'minmax'

    // ── Quantitative pipeline options ────────────────────────────────────────
    quant_stats             = 'mean,median,std'
    quant_phenotypes        = null      // null = all; comma list or file

    // ── Categorical pipeline options ─────────────────────────────────────────
    cat_phenotypes          = null
    missing_as_control      = false
    min_occurrences         = 1

    // ── Diagnostic chunking (parallelisation) ────────────────────────────────
    // Split coded phenotypes into chunks of N codes per job.
    // Each chunk runs as a separate parallel PREPROCESS job. 0 = disabled.
    // Recommended for large biobanks with thousands of unique ICD codes.
    coded_chunk_size   = 500

    // ── Sample chunking (parallelisation) ────────────────────────────────────
    // Set chunk_size > 0 to split the long-format file into sample partitions
    // and process each chunk in parallel.  0 = disabled (single-process, default).
    // Recommended for cohorts with > 50 k samples.
    //   BASIC_QUANTITATIVE: chunking is safe for all stats except qcut_bins,
    //     where bin edges will differ between chunks (see module comment).
    //   BASIC_CATEGORICAL:  chunking is always safe (no global statistics).
    chunk_size              = 0

    // ── Output ────────────────────────────────────────────────────────────────
    output_dir              = 'results'
}

// ── Default resource limits ───────────────────────────────────────────────────
includeConfig 'conf/base.config'

// ── Profiles ─────────────────────────────────────────────────────────────────

profiles {
    // Local execution with Docker
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        process.container      = 'pmbb-phenotyping:latest'
    }

    // Local execution with Singularity
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'pmbb-phenotyping.sif'
    }

    // Test profile: uses test_data/, minimal resources
    test {
        includeConfig 'conf/test.config'
    }

    // HPC / SLURM profile
    slurm {
        includeConfig 'conf/slurm.config'
    }

    // HPC / LSF profile
    lsf {
        includeConfig 'conf/lsf.config'
    }
}

// ── Execution reporting ───────────────────────────────────────────────────────
report {
    enabled = true
    file    = "${params.output_dir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.output_dir}/pipeline_timeline.html"
}
